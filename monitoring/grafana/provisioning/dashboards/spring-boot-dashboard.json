{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "🏥 Application Health",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } }, "type": "value" }],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "targets": [{ "expr": "up{job=\"spring-boot-backend\"}", "legendFormat": "Backend" }]
    },
    {
      "title": "⏱️ Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [{ "expr": "process_uptime_seconds{job=\"spring-boot-backend\"}", "legendFormat": "Uptime" }]
    },
    {
      "title": "📊 HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "rate(http_server_requests_seconds_count{job=\"spring-boot-backend\"}[1m])", "legendFormat": "{{method}} {{uri}} ({{status}})" }
      ]
    },
    {
      "title": "⚡ Response Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job=\"spring-boot-backend\"}[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket{job=\"spring-boot-backend\"}[5m]))", "legendFormat": "p50" }
      ]
    },
    {
      "title": "🧠 JVM Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "expr": "jvm_memory_used_bytes{job=\"spring-boot-backend\", area=\"heap\"}", "legendFormat": "Heap Used ({{id}})" },
        { "expr": "jvm_memory_committed_bytes{job=\"spring-boot-backend\", area=\"heap\"}", "legendFormat": "Heap Committed ({{id}})" }
      ]
    },
    {
      "title": "🔌 HikariCP Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "hikaricp_connections_active{job=\"spring-boot-backend\"}", "legendFormat": "Active" },
        { "expr": "hikaricp_connections_idle{job=\"spring-boot-backend\"}", "legendFormat": "Idle" },
        { "expr": "hikaricp_connections{job=\"spring-boot-backend\"}", "legendFormat": "Total" },
        { "expr": "hikaricp_connections_pending{job=\"spring-boot-backend\"}", "legendFormat": "Pending" }
      ]
    },
    {
      "title": "🗑️ JVM Garbage Collection",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "rate(jvm_gc_pause_seconds_sum{job=\"spring-boot-backend\"}[5m])", "legendFormat": "GC Pause {{action}} {{cause}}" }
      ]
    },
    {
      "title": "🧵 JVM Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "jvm_threads_live_threads{job=\"spring-boot-backend\"}", "legendFormat": "Live Threads" },
        { "expr": "jvm_threads_daemon_threads{job=\"spring-boot-backend\"}", "legendFormat": "Daemon Threads" },
        { "expr": "jvm_threads_peak_threads{job=\"spring-boot-backend\"}", "legendFormat": "Peak Threads" }
      ]
    },
    {
      "title": "❌ HTTP Error Rate (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "rate(http_server_requests_seconds_count{job=\"spring-boot-backend\", status=~\"4..\"}[5m])", "legendFormat": "4xx {{uri}}" },
        { "expr": "rate(http_server_requests_seconds_count{job=\"spring-boot-backend\", status=~\"5..\"}[5m])", "legendFormat": "5xx {{uri}}" }
      ]
    },
    {
      "title": "💾 Redis Cache Operations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "expr": "rate(cache_gets_total{job=\"spring-boot-backend\", result=\"hit\"}[5m])", "legendFormat": "Cache Hit ({{name}})" },
        { "expr": "rate(cache_gets_total{job=\"spring-boot-backend\", result=\"miss\"}[5m])", "legendFormat": "Cache Miss ({{name}})" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["spring-boot", "jvm", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Smart Resource Planner - Backend Monitoring",
  "uid": "smart-resource-planner",
  "version": 1
}
